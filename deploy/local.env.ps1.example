# Local deploy + CI/CD constants — NOT committed.
# Setup (once per machine / repo clone):
#   Copy-Item deploy\local.env.ps1.example deploy\local.env.ps1
#   Edit values, then sync GitHub Actions variables:
#   .\deploy\scripts\set-github-cicd-vars.ps1
#
# Load in PowerShell:
#   Set-Location (git rev-parse --show-toplevel)
#   . .\deploy\local.env.ps1

# --- Azure (local kubectl / az CLI) ---
$DndAzureResourceGroup = "rg-your-project"
$DndAksCluster = "aks-your-cluster"
$DndKubectlContext = "aks-your-cluster"

# --- GitHub (bootstrap OIDC; optional — script can infer from gh repo view) ---
$DndGitHubOrg = ""              # empty = gh repo view owner
$DndGitHubRepo = ""             # empty = gh repo view name
$DndDefaultBranch = "master"

# --- GHCR image names (without owner prefix) ---
$DndGhcrApiPackage = "yourapp-api"
$DndGhcrWebPackage = "yourapp-web"

# --- K8s auto-deploy target (CD workflow) ---
$DndNamespacePrefix = "yourapp"           # namespace: {prefix}-{env} e.g. yourapp-test
$DndCdDeployEnvironment = "test"          # Build-Overlay -Environment
$DndCdIngressHost = "yourapp-test.local"  # Ingress Host header for smoke

# --- OIDC bootstrap (optional overrides) ---
$DndOidcAppDisplayName = "yourapp-github-actions"
$DndOidcFederatedCredentialName = "github-yourapp-master"

# Short aliases for runbooks
$RG = $DndAzureResourceGroup
$CLUSTER = $DndAksCluster
